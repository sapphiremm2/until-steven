<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark translucent base -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="135"
                android:endColor="#C5080808"
                android:startColor="#D0121212"
                android:type="linear" />
        </shape>
    </item>
    <!-- Subtle top-edge glass sheen -->
    <item android:bottom="60%">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#08FFFFFF" />
        </shape>
    </item>
    <!-- 1dp white border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="#22FFFFFF" />
        </shape>
    </item>
</layer-list>
